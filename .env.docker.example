# Copy to the repo root as `.env` for docker compose:
#   cp .env.docker.example .env
#
# Required: set TOKEN_SECRET (e.g. node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")

TOKEN_SECRET=

# PostgreSQL (defaults match compose fallbacks)
DB_USER=home4strays
DB_PASSWORD=home4strays
DB_DATABASE=home4strays

# MinIO root credentials (used as S3 access key / secret)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin12
MINIO_BUCKET_NAME=home4strays

# URL the browser uses for stored objects (must match MINIO_API_PORT mapping, default 9000)
MINIO_PUBLIC_URL=http://localhost:9000

# Optional host port overrides
# POSTGRES_PUBLISH_PORT=5432
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# BACKEND_PUBLISH_PORT=3100
# FRONTEND_PUBLISH_PORT=3000
# ADMINER_PUBLISH_PORT=3400

# Next.js server-side proxy to Express (leave default for Docker; use http://localhost:3100 only if debugging from host)
# BACKEND_URL=http://backend:3100

# Invite links base (optional)
# PUBLIC_URL=http://localhost:3000

# Outbound email (optional; leave empty if unused)
# EMAIL=
# EMAIL_PASSWORD=
